              "type": "string",
              "title": "Doc Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentDetail"
                }
              }
            }
          },
          "401": {
            "description": "认证失败",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          },
          "404": {
            "description": "资源不存在",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          },
          "503": {
            "description": "服务暂不可用（未就绪或队列已满）",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AnswerCreateRequest": {
        "properties": {
          "question": {
            "type": "string",
            "minLength": 1,
            "title": "Question",
            "description": "面向 CAE 知识库的自然语言问题（中文或英文）"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "question"
        ],
        "title": "AnswerCreateRequest",
        "description": "Body of POST /v1/answers; unknown fields are rejected.",
        "examples": [
          {
            "question": "HJC 本构模型模拟混凝土受冲击时主要考虑哪些效应？"
          }
        ]
      },
      "AnswerError": {
        "properties": {
          "code": {
            "type": "string",
            "title": "Code"
          },
          "message": {
            "type": "string",
            "title": "Message"
          }
        },
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "title": "AnswerError"
      },
      "AnswerResource": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id",
            "examples": [
              "ans_a1b2c3d4e5f60718"
            ]
          },
          "object": {
            "type": "string",
            "const": "answer",
            "title": "Object",
            "default": "answer"
          },
          "status": {
            "type": "string",
            "enum": [
              "queued",
              "running",
              "succeeded",
              "failed"
            ],
            "title": "Status"
          },
          "question": {
            "type": "string",
            "title": "Question"
          },
          "answer": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Answer",
            "description": "终答文本；succeeded 时非空"
          },
          "sources": {
            "items": {
              "$ref": "#/components/schemas/SourceDoc"
            },
            "type": "array",
            "title": "Sources",
            "description": "作答过程实际打开阅读过的文档（不含仅在检索结果中出现的候选）"
          },
          "usage": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/AnswerUsage"
              },
              {
                "type": "null"
              }
            ]
          },
          "forced_final": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Forced Final",
            "description": "是否在轮数耗尽时被强制收敛作答"
          },
          "created_at": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Created At",
            "description": "ISO 8601 UTC"
          },
          "started_at": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Started At"
          },
          "finished_at": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Finished At"
          },
          "latency_ms": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Latency Ms",
            "description": "从开始执行到完成的耗时"
          },
          "error": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/AnswerError"
              },
              {
                "type": "null"
              }
            ],
            "description": "failed 时的错误详情"
          }
        },
        "type": "object",
        "required": [
          "id",
          "status",
          "question"
        ],
        "title": "AnswerResource",
        "description": "One answer job; the same shape is returned by POST and GET."
      },
      "AnswerUsage": {
        "properties": {
          "iterations": {
            "type": "integer",
            "title": "Iterations",
            "description": "agent 检索↔阅读回环轮数"
          },
          "total_tokens": {
            "type": "integer",
            "title": "Total Tokens",
            "description": "本次作答消耗的 LLM token 总量"
          },
          "compactions": {
            "type": "integer",
            "title": "Compactions",
            "description": "工作记忆压缩次数"
          },
          "documents_read": {
            "type": "integer",
            "title": "Documents Read",
            "description": "实际打开阅读过的文档数",
            "default": 0
          },
          "documents_seen": {
            "type": "integer",
            "title": "Documents Seen",
            "description": "检索结果中出现过的候选文档数",
            "default": 0
          }
        },
        "type": "object",
        "required": [
          "iterations",
          "total_tokens",
          "compactions"
        ],
        "title": "AnswerUsage"
      },
      "DocumentDetail": {
        "properties": {
          "doc_id": {
            "type": "string",
            "title": "Doc Id"
          },
          "title": {
            "type": "string",
            "title": "Title"
          },
          "language": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Language"
          },
          "tldr": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Tldr"
          },
          "abstract": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Abstract"
          },
          "keywords": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Keywords"
          },
          "token_count": {
            "type": "integer",
            "title": "Token Count"
          },
          "sections": {
            "items": {
              "$ref": "#/components/schemas/SectionSummary"
            },
            "type": "array",
            "title": "Sections"
          }
        },
        "type": "object",
        "required": [
          "doc_id",
          "title",
          "token_count"
        ],
        "title": "DocumentDetail"
      },
      "DocumentList": {
        "properties": {
          "object": {
            "type": "string",
            "const": "list",
            "title": "Object",
            "default": "list"
          },
          "data": {
            "items": {
              "$ref": "#/components/schemas/DocumentSummary"
            },
            "type": "array",
            "title": "Data"
          },
          "total": {
            "type": "integer",
            "title": "Total"
          },
          "limit": {
            "type": "integer",
            "title": "Limit"
          },
          "offset": {
            "type": "integer",
            "title": "Offset"
          }
        },
        "type": "object",
        "required": [
          "data",
          "total",
          "limit",
          "offset"
        ],
        "title": "DocumentList"
      },
      "DocumentSummary": {
        "properties": {
          "doc_id": {
            "type": "string",
            "title": "Doc Id"
          },
          "title": {
            "type": "string",
            "title": "Title"
          },
          "language": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Language"
          },
          "tldr": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Tldr"
          },
          "token_count": {
            "type": "integer",
            "title": "Token Count"
          },
          "section_count": {
            "type": "integer",
            "title": "Section Count"
          }
        },
        "type": "object",
        "required": [
          "doc_id",
          "title",
          "token_count",
          "section_count"
        ],
        "title": "DocumentSummary"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "Problem": {
        "properties": {
          "type": {
            "type": "string",
            "title": "Type"
          },
          "title": {
            "type": "string",
            "title": "Title"
          },
          "status": {
            "type": "integer",
            "title": "Status"
          },
          "detail": {
            "type": "string",
            "title": "Detail"
          },
          "code": {
            "type": "string",
            "title": "Code"
          },
          "request_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Request Id"
          }
        },
        "additionalProperties": true,
        "type": "object",
        "required": [
          "type",
          "title",
          "status",
          "detail",
          "code"
        ],
        "title": "Problem",
        "description": "RFC 9457 problem document; every non-2xx response uses this shape.",
        "examples": [
          {
            "code": "rate_limited",
            "detail": "API key exceeded 10 req/min",
            "request_id": "req_1a2b3c4d",
            "retry_after": 42,
            "status": 429,
            "title": "Too Many Requests",
            "type": "https://deepreadqa.dev/errors/rate-limited"
          }
        ]
      },
      "SectionSummary": {
        "properties": {
          "idx": {
            "type": "integer",
            "title": "Idx"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "tldr": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Tldr"
          },
          "token_count": {
            "type": "integer",
            "title": "Token Count"
          }
        },
        "type": "object",
        "required": [
          "idx",
          "name",
